---
import "./styles.css";
import Nav from "./components/nav.tsx";
import Footer from "./components/footer.astro";

import {
    Modal,
    ModalHeader,
    ModalBody,
    ModalFooter,
} from "free-astro-components";

import { getCollection } from "astro:content";
import type { EventData } from "@/content/config";

type EventEntry = {
    id: string;
    data: EventData;
    collection: string;
};

type EventNav = {
    title: string;
    href: string;
    desc?: string;
};

const eventEntries = (await getCollection("events")) as EventEntry[];

const events = [
    {
        title: "Coming soon",
        href: "https://buildingblocs.notion.site/343104f6313d80c8a3f2da6bded7b2cf",
        desc: "Join the newsletter to get notified",
    },
    {
        title: "Looking for older events?",
        href: "/archive",
    },
];

let eventPages: EventNav[] = [];

if (eventEntries && eventEntries.length != 0) {
    eventPages = [
        ...eventEntries.map((entry) => ({
            title: entry.data.title,
            desc: entry.data.openExcerpt,
            href: `/${entry.collection}/${entry.id}`,
        })),
        events[events.length - 1],
    ];
} else {
    eventPages = [...events];
}

const { title, showTitle, desc } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={desc} />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title} | BuildingBloCS</title>
    </head>
    <body class="bg-slate-950">
        <Nav client:load data={eventPages} />

        {showTitle && <h1 class="text-center mt-10 mb-5 mx-5">{title}</h1>}
        <slot />

        <Footer />
        <Modal id="modal-contact" class="contact-modal">
            <ModalHeader class="contact-modal-header">
                <h2>Contact us!</h2>
            </ModalHeader>
            <ModalBody>
                <div>
                    <p>
                        Email: <a href="mailto:hello@buildingblocs.sg"
                            >hello@buildingblocs.sg</a
                        >
                    </p>
                    <p>
                        Instagram: <a
                            href="https://www.instagram.com/buildingblocs26"
                            >@buildingblocs26</a
                        >
                    </p>
                    <p>
                        <a
                            href="https://go.buildingblocs.sg/discord"
                            rel="noopener noreferrer"
                            target="_blank">Join our Discord!</a
                        >
                    </p>
                </div>
            </ModalBody>
        </Modal>
    </body>
</html>
