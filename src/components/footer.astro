---
import { Image } from "astro:assets";
import logo from "../img/colour_sidetext_dark.svg";
import {
    InstagramLogoIcon,
    GitHubLogoIcon,
    DiscordLogoIcon,
} from "@radix-ui/react-icons";
import { getCollection } from "astro:content";
import type { EventData } from "@/content/config";
import { Button } from "@/components/ui/button";
import { ArrowRightIcon } from "@radix-ui/react-icons";
import cta from "@/img/index/cta.webp";

type Page = {
    title: string;
    link: string;
};

const pages = [
    {
        title: "Home",
        link: "/",
    },
    {
        title: "Our Partners",
        link: "/partners",
    },
    {
        title: "Our Team",
        link: "/team",
    },
    {
        title: "Archive",
        link: "/archive",
    },
];

type EventEntry = {
    id: string;
    data: EventData;
    collection: string;
};

const eventEntries = (await getCollection("events")) as EventEntry[];

let eventPages: Page[] = [];

if (eventEntries && eventEntries.length != 0) {
    eventPages = [
        ...pages,
        ...eventEntries.map((entry) => ({
            title: entry.data.title,
            link: `/${entry.collection}/${entry.id}`,
        })),
    ];
} else {
    eventPages = [...pages];
}
---

<footer class="mx-auto max-w-7xl py-12 sm:px-6 lg:px-8">
    <div
        class="relative isolate lg:flex-col overflow-hidden bg-gray-900 dark:bg-slate-900 px-6 pt-16 sm:pt-32 shadow-2xl sm:rounded-3xl sm:px-16 md:pt-3 lg:flex lg:gap-x-20 xl:gap-x-20 lg:px-24 lg:pt-0"
    >
        <svg
            viewBox="0 0 1024 1024"
            class="absolute left-1/2 top-1/2 -z-10 h-[64rem] w-[64rem] -translate-y-1/2 [mask-image:radial-gradient(closest-side,white,transparent)] sm:left-full sm:-ml-80 lg:left-1/2 lg:ml-0 lg:-translate-x-1/2 lg:translate-y-0"
            aria-hidden="true"
        >
            <circle
                cx="512"
                cy="512"
                r="512"
                fill="url(#759c1415-0410-454c-8f7c-9a820de03641)"
                fill-opacity="0.7"></circle>
            <defs>
                <radialGradient id="759c1415-0410-454c-8f7c-9a820de03641">
                    <stop stop-color="#7775D6"></stop>
                    <stop offset="1" stop-color="#E935C1"></stop>
                </radialGradient>
            </defs>
        </svg>

        <div class="flex mx-10">
            <div class="max-w-xs flex justify-center flex-col text-left">
                <h2>Join us!</h2>
                <p class="mt-3">for the December Conference to learn coding, the best way.</p>
                <div class="mt-6 flex items-center justify-center gap-x-6 lg:justify-start">
                    <a href="/events/december">
                        <Button>
                            Learn more
                            <ArrowRightIcon className="w-4 ml-1" />
                        </Button>
                    </a>
                </div>
            </div>
            <div class="pt-7 flex-1">
                <Image alt="A lady with a FossAsia lanyard holding a laptop in a auditorium" class="lg:rounded-l-lg rounded-t-lg" src={cta} loading=eager />
            </div>
        </div>

        <div class="flex flex-col w-full pb-10">
            <hr class="border-white/30" />
            <a href="/">
                <Image
                    src={logo}
                    alt="BuildingBloCS's logo"
                    class="h-10 w-auto mt-6 mb-4"
                />
            </a>
            <ul
                class="flex gap-x-4 ml-2 text-slate-200 flex-col sm:flex-row gap-y-2"
            >
                {
                    eventPages.map((page) => (
                        <li>
                            <a href={page.link} class="hover:underline">
                                {page.title}
                            </a>
                        </li>
                    ))
                }
            </ul>
            <div class="flex ml-2 mt-6 gap-x-6">
                <a
                    aria-label="Our Instagram"
                    href="https://instagram.com/buildingblocs26"
                >
                    <InstagramLogoIcon
                        className="text-slate-200 hover:text-slate-400 transition w-5 h-5"
                    />
                </a>
                <a
                    aria-label="Our GitHub"
                    href="https://github.com/buildingblocs"
                >
                    <GitHubLogoIcon
                        className="text-slate-200 hover:text-slate-400 transition w-5 h-5"
                    />
                </a>
                <a
                    aria-label="Our Discord"
                    href="https://discord.gg/VSHyrbsJFs"
                >
                    <DiscordLogoIcon
                        className="text-slate-200 hover:text-slate-400 transition w-5 h-5"
                    />
                </a>
                <a
                    aria-label="Our YouTube"
                    href="https://youtube.com/buildingblocssg"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="17"
                        height="16"
                        fill="currentColor"
                        class="text-slate-200 hover:text-slate-400 transition w-5 h-5"
                        viewBox="0 0 16 16"
                    >
                        <path
                            d="M8.051 1.999h.089c.822.003 4.987.033 6.11.335a2.01 2.01 0 0 1 1.415 1.42c.101.38.172.883.22 1.402l.01.104.022.26.008.104c.065.914.073 1.77.074 1.957v.075c-.001.194-.01 1.108-.082 2.06l-.008.105-.009.104c-.05.572-.124 1.14-.235 1.558a2.01 2.01 0 0 1-1.415 1.42c-1.16.312-5.569.334-6.18.335h-.142c-.309 0-1.587-.006-2.927-.052l-.17-.006-.087-.004-.171-.007-.171-.007c-1.11-.049-2.167-.128-2.654-.26a2.01 2.01 0 0 1-1.415-1.419c-.111-.417-.185-.986-.235-1.558L.09 9.82l-.008-.104A31 31 0 0 1 0 7.68v-.123c.002-.215.01-.958.064-1.778l.007-.103.003-.052.008-.104.022-.26.01-.104c.048-.519.119-1.023.22-1.402a2.01 2.01 0 0 1 1.415-1.42c.487-.13 1.544-.21 2.654-.26l.17-.007.172-.006.086-.003.171-.007A100 100 0 0 1 7.858 2zM6.4 5.209v4.818l4.157-2.408z"
                        ></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</footer>

